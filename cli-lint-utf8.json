: {\n      ttlMs: 86_400_000,\n    },\n    entries,\n  };\n\n  // Apply deterministic normalization for B2\n  const normalized = normalizeManifest(manifest);\n\n  // Emit quality metadata: store rejected entries count in build metadata\n  if (rejectedEntries.length > 0) {\n    (normalized.build as any).__quality_rejected_entries = rejectedEntries;\n  }\n\n  return normalized;\n}\n\nexport function renderManifestJson(\n  manifest: BlueprintManifest,\n  options: { prettyPrint?: boolean } = {}\n): string {\n  const spacing = options.prettyPrint === false ? 0 : 2;\n  return `${JSON.stringify(manifest, null, spacing)}\\n`;\n}\n","usedDeprecatedRules":[]},{"filePath":"E:\\Projects and Learning\\skelcore\\packages\\cli\\src\\emit\\report-writer.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"E:\\Projects and Learning\\skelcore\\packages\\cli\\src\\emit\\rollout-dashboard.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"E:\\Projects and Learning\\skelcore\\packages\\cli\\src\\index.ts","messages":[{"ruleId":"prettier/prettier","severity":2,"message":"Replace `풉칀츿較석뎼較석뎼較석뎼較석뎼typeof較석뎼module較석뎼!==較석뎼\"undefined\"較석뎼&&풉칀츿較석뎼較석뎼較석뎼` with `較석뎼typeof較석뎼module較석뎼!==較석뎼\"undefined\"較석뎼&&`","line":44,"column":37,"messageId":"replace","endLine":46,"endColumn":4,"fix":{"range":[1437,1478],"text":" typeof module !== \"undefined\" &&"}}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":1,"fixableWarningCount":0,"source":"#!/usr/bin/env node\nimport { runCaptureCommand } from \"./commands/capture-command\";\nimport { runDiffCommand } from \"./commands/diff-command\";\nimport { runReportCommand } from \"./commands/report-command\";\nimport { runRolloutCommand } from \"./commands/rollout-command\";\nimport { runValidateCommand } from \"./commands/validate-command\";\nimport type { CliIo } from \"./types\";\n\nconst defaultIo: CliIo = {\n  log: (message) => console.log(message),\n  error: (message) => console.error(message),\n};\n\nconst DIRECT_INVOCATION_PATH_RE = /[\\\\/]dist[\\\\/](index|build)\\.(js|cjs)$/;\n\nexport function isCliDirectInvocationPath(invokedPath: string): boolean {\n  return DIRECT_INVOCATION_PATH_RE.test(invokedPath);\n}\n\nexport async function runCli(argv: string[], io: CliIo = defaultIo): Promise<number> {\n  const [command, ...rest] = argv;\n\n  switch (command) {\n    case undefined:\n    case \"capture\":\n      return runCaptureCommand(rest, io);\n    case \"validate\":\n      return runValidateCommand(rest, io);\n    case \"diff\":\n      return runDiffCommand(rest, io);\n    case \"report\":\n      return runReportCommand(rest, io);\n    case \"rollout\":\n      return runRolloutCommand(rest, io);\n    default:\n      io.error(`Unknown command: ${command}`);\n      io.error(\"Supported commands: capture, validate, diff, report, rollout\");\n      return 1;\n  }\n}\n\nconst invokedPath = process.argv[1] ?? \"\";\nconst isDirectInvocation =\n  (typeof require !== \"undefined\" &&\n    typeof module !== \"undefined\" &&\n    require.main === module) ||\n  isCliDirectInvocationPath(invokedPath);\n\nif (isDirectInvocation) {\n  runCli(process.argv.slice(2)).then((code) => {\n    process.exitCode = code;\n  });\n}\n\nexport type { CaptureConfig, CliIo } from \"./types\";\n","usedDeprecatedRules":[]},{"filePath":"E:\\Projects and Learning\\skelcore\\packages\\cli\\src\\quality\\manifest-diff.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"E:\\Projects and Learning\\skelcore\\packages\\cli\\src\\quality\\manifest-quality.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,