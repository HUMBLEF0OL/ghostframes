{
    "name": "@skelcore/skelcore",
    "version": "0.1.0",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "bin": {
        "skelcore": "./dist/build.js"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs",
            "default": "./dist/index.js"
        },
        "./react": {
            "types": "./dist/react.d.ts",
            "import": "./dist/react.js",
            "require": "./dist/react.cjs",
            "default": "./dist/react.js"
        },
        "./runtime": {
            "types": "./dist/runtime.d.ts",
            "import": "./dist/runtime.js",
            "require": "./dist/runtime.cjs",
            "default": "./dist/runtime.js"
        },
        "./build": {
            "types": "./dist/build.d.ts",
            "import": "./dist/build.js",
            "require": "./dist/build.cjs",
            "default": "./dist/build.js"
        }
    },
    "sideEffects": false,
    "files": [
        "dist",
        "README.md",
        "CHANGELOG.md"
    ],
    "scripts": {
        "build": "tsup src/index.ts src/react.ts src/runtime.ts src/build.ts --format cjs,esm --dts",
        "dev": "tsup src/index.ts src/react.ts src/runtime.ts src/build.ts --format cjs,esm --watch --dts",
        "lint": "eslint src --config ../../eslint.config.mjs",
        "test": "vitest run",
        "typecheck": "tsc --noEmit"
    },
    "peerDependencies": {
        "react": ">=18",
        "react-dom": ">=18"
    },
    "dependencies": {
        "@skelcore/cli": "workspace:*",
        "@skelcore/core": "workspace:*",
        "@skelcore/react": "workspace:*"
    },
    "devDependencies": {
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "tsup": "^8.5.1",
        "typescript": "^6.0.2",
        "vitest": "^4.1.2"
    }
}